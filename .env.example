# ── ChromaDB ────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_TOKEN=pharmarag_secret
COLLECTION_NAME=pharmavigilance

# ── Ollama / LLM ────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=mistral
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ── Embeddings ──────────────────────────────────────────
EMBEDDING_MODEL=dmis-lab/biobert-base-cased-v1.2
EMBEDDING_DEVICE=cpu

# ── Retrieval ───────────────────────────────────────────
TOP_K_RESULTS=5
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── FDA FAERS API ───────────────────────────────────────
FAERS_BASE_URL=https://api.fda.gov/drug/event.json
FAERS_API_KEY=